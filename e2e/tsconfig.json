{
  "extends": "../tsconfig.json",
  "compilerOptions": {
    // e2e tests include page.evaluate() callbacks that run in the browser,
    // so DOM types are needed alongside the standard ESNext lib.
    "lib": ["ESNext", "DOM"]
  },
  "include": ["."],
  // Override parent's exclude — this tsconfig IS the e2e check.
  "exclude": []
}
