{
  "compilerOptions": {
    // Environment setup & latest features
    "lib": ["ESNext"],

    "target": "ESNext",
    "module": "Preserve",
    "moduleDetection": "force",
    "jsx": "react-jsx",
    "allowJs": true,

    // Bundler mode
    "moduleResolution": "bundler",
    "allowImportingTsExtensions": true,
    "verbatimModuleSyntax": true,
    "noEmit": true,

    // Best practices
    "strict": true,
    "skipLibCheck": true,
    "noFallthroughCasesInSwitch": true,
    "noUncheckedIndexedAccess": true,
    "noImplicitOverride": true,

    // TS 6.0: types now defaults to [] — explicitly include @types/bun
    "types": ["bun"],

    // Some stricter flags (disabled by default)
    "noUnusedLocals": false,
    "noUnusedParameters": false,
    "noPropertyAccessFromIndexSignature": false
  },
  // Exclude directories that have their own tsconfig with different settings
  // (e.g. src/web/client needs DOM lib; e2e needs DOM for page.evaluate callbacks).
  "exclude": ["src/web/client", "e2e"]
}
