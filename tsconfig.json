{
  "compilerOptions": {
    // Environment setup & latest features
    "lib": ["ESNext"],

    "target": "ESNext",
    "module": "Preserve",
    "moduleDetection": "force",
    "jsx": "react-jsx",
    "allowJs": true,

    // Bundler mode
    "moduleResolution": "bundler",
    "allowImportingTsExtensions": true,
    "verbatimModuleSyntax": true,
    "noEmit": true,

    // Best practices
    "strict": true,
    "skipLibCheck": true,
    "noFallthroughCasesInSwitch": true,
    "noUncheckedIndexedAccess": true,
    "noImplicitOverride": true,

    // TS 6.0: types now defaults to [] — explicitly include @types/bun
    "types": ["bun"],

    // Some stricter flags (disabled by default)
    "noUnusedLocals": false,
    "noUnusedParameters": false,
    "noPropertyAccessFromIndexSignature": false
  },
  // Phase 3.7: `src/` was retired alongside the SolidJS frontend.
  // The only TypeScript that survives is `e2e/` (Playwright specs),
  // which has its own tsconfig with `lib: ["ESNext", "DOM"]`. This
  // root tsconfig is no longer the entry point for any typecheck —
  // see `e2e/tsconfig.json`. It stays alongside `package.json`
  // until Phase 4 retires the JS toolchain wholesale.
  "exclude": ["e2e", "node_modules"]
}
