{
  "extends": "../../../tsconfig.json",
  "compilerOptions": {
    "lib": ["ESNext", "DOM"],
    "jsx": "preserve",
    "jsxImportSource": "solid-js",
    "noEmit": true,
    // TS 6.0: noUncheckedSideEffectImports defaults to true; CSS imports are bundler-handled
    "noUncheckedSideEffectImports": false
