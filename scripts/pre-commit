#!/bin/sh
# Pre-commit hook: run the quality gate before every commit.
# Install via: just install-hooks
#
# Aborts the commit if anything fails.

# ---------------------------------------------------------------------------
# Docs-only fast path: skip the gate when every staged file is a doc or
# backlog file (*.md anywhere, or anything under docs/ or backlog/).
# Code changes always go through the full gate.
# ---------------------------------------------------------------------------
STAGED=$(git diff --cached --name-only)
NON_DOCS=$(printf '%s\n' $STAGED | grep -vE '(\.md$|^docs/|^backlog[./])')
if [ -z "$STAGED" ]; then
  echo "✅  Nothing staged."
  exit 0
fi
if [ -z "$NON_DOCS" ]; then
  echo "✅  Docs-only change — skipping gate."
  exit 0
fi

# ---------------------------------------------------------------------------
# Auto-format Rust: always run cargo fmt on both workspaces and re-stage
# any .rs files the formatter changed, wherever they live in the tree.
# Formatting is an action, not a check — it is never a reason for the gate
# to fail.
# ---------------------------------------------------------------------------
echo "Auto-formatting Rust code..."
(cd rust && cargo fmt)
(cd frontends/leptos && cargo fmt)
# Re-stage every .rs file that cargo fmt changed (modified or newly added).
# `git diff --name-only` lists files whose working-tree content now differs
# from the index — exactly what the formatter touched, at any depth.
FMT_CHANGED=$(git diff --name-only | grep '\.rs$' || true)
if [ -n "$FMT_CHANGED" ]; then
  echo "$FMT_CHANGED" | xargs git add
fi
echo "✅  Rust code formatted and re-staged."

# ---------------------------------------------------------------------------
# Rust-only fast path: if every non-doc staged file lives under rust/, run
# `just rust-gate` (faster subset, skips the e2e browser run) instead of
# the full gate.
# ---------------------------------------------------------------------------
RUST_ONLY=$(printf '%s\n' $NON_DOCS | grep -v '^rust/')
if [ -z "$RUST_ONLY" ]; then
  echo "Running just rust-gate..."
  just rust-gate > /dev/null
  status=$?
  if [ $status -ne 0 ]; then
    echo ""
    echo "❌  Rust gate failed — commit aborted."
    echo "    Run: just fmt && cargo clippy && cargo test"
    exit 1
  fi
  echo "✅  Rust gate passed."
  exit 0
fi

# ---------------------------------------------------------------------------
# Run the full gate (Leptos build/test/snapshots + Rust checks + e2e).
# ---------------------------------------------------------------------------
# Clear git plumbing variables that git sets when running hooks with -a.
# Without this, GIT_INDEX_FILE points to the parent commit's index lock,
# and any git commands run by tests (e.g. in isolated temp repos) would
# write into that lock file, corrupting the staged index.
unset GIT_INDEX_FILE GIT_DIR GIT_WORK_TREE

echo "Running just gate..."
# Suppress stdout — gate writes its full output to test-output/gate-latest.log
# internally via `tee`, so the log is always up-to-date regardless.
# Keeping stdout silent here prevents ~60 KB of build/test output from being
# fed back to the LLM as tool-result content on every successful commit.
just gate > /dev/null
status=$?

if [ $status -ne 0 ]; then
  echo ""
  echo "❌  Gate failed — commit aborted."
  echo "    Tail of test-output/gate-latest.log:"
  echo ""
  if [ -f test-output/gate-latest.log ]; then
    tail -60 test-output/gate-latest.log
  else
    echo "    (log file not found)"
  fi
  echo ""
  echo "    Full log: test-output/gate-latest.log"
  echo "    To skip this check (emergency only): git commit --no-verify"
  exit 1
fi

echo "✅  Gate passed. Full log: test-output/gate-latest.log"
exit 0
