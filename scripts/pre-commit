#!/bin/sh
# Pre-commit hook: run the full quality gate before every commit.
# Install via: just install-hooks
#
# Aborts the commit if anything fails.

# ---------------------------------------------------------------------------
# Guard: catch bare `new Agent()` with no arguments in test files.
# A no-arg Agent() in a test could write to production paths.
# Use makeTestAgent() from src/test-utils.ts instead.
# ---------------------------------------------------------------------------
echo "Checking for unsafe Agent construction in tests..."
if grep -rn --include="*.test.ts" "new Agent()" src/ 2>/dev/null | grep -qv "makeTestAgent"; then
  echo ""
  echo "❌  Unsafe Agent construction found in test files:"
  grep -rn --include="*.test.ts" "new Agent()" src/ | grep -v "makeTestAgent"
  echo ""
  echo "    Use makeTestAgent() from src/test-utils.ts instead of new Agent()."
  echo "    To skip this check (emergency only): git commit --no-verify"
  exit 1
fi
echo "✅  No unsafe Agent construction."

# ---------------------------------------------------------------------------
# Run the full gate: typecheck + all tests (unit + browser) + knip.
# ---------------------------------------------------------------------------
# Clear git plumbing variables that git sets when running hooks with -a.
# Without this, GIT_INDEX_FILE points to the parent commit's index lock,
# and any git commands run by tests (e.g. in isolated temp repos) would
# write into that lock file, corrupting the staged index.
unset GIT_INDEX_FILE GIT_DIR GIT_WORK_TREE

echo "Running just gate..."
just gate
status=$?

if [ $status -ne 0 ]; then
  echo ""
  echo "❌  Gate failed — commit aborted."
  echo "    Fix the failures, then commit again."
  echo "    To skip this check (emergency only): git commit --no-verify"
  exit 1
fi

echo "✅  Gate passed."
exit 0
