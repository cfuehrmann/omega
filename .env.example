# Copy this file to .env and fill in real values.
# .env is gitignored — never commit real secrets.
#
# omega-server and omega-cli load this file automatically at startup
# (via dotenvy, walking up from the working directory).
# In production / CI, inject these as real environment variables instead.

# Required: Anthropic API key for the Claude models.
ANTHROPIC_API_KEY=sk-ant-...

# Required: Brave Search API key for the web_search tool.
# Get one at https://brave.com/search/api/
BRAVE_SEARCH_API_KEY=BSA...
