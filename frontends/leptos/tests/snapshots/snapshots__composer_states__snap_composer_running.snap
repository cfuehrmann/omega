<section data-testid="leptos-composer" data-turn-state="running" class="leptos-composer"><button data-testid="leptos-composer-sessions" data-panel-open="false" class="leptos-composer-sessions">Sessions</button><button data-testid="leptos-composer-usage" data-panel-open="false" class="leptos-composer-usage">▼ Usage</button><select data-testid="leptos-composer-model" class="leptos-composer-model"><option value="claude-sonnet-4-6">Sonnet</option><option value="claude-opus-4-8">Opus 4.8</option><!></select><select data-testid="leptos-composer-effort" class="leptos-composer-effort"><option value="low">Low</option><option value="medium">Medium</option><option value="high">High</option><option value="max">Max</option><!></select><div class="leptos-composer-textarea-wrap"><!><!--<() />--><textarea data-testid="leptos-composer-input" placeholder="Message Omega… (@ for file, Enter to send, Shift+Enter for newline)" class="leptos-composer-input"></textarea></div><button data-testid="leptos-composer-halt" class="leptos-composer-halt">Halt ⎋</button><!><!--<() />--><button data-testid="leptos-composer-abort" class="leptos-composer-abort">Abort ⎋</button><button data-testid="leptos-composer-primary" data-action="send" class="leptos-composer-primary">Send ⏎</button><div data-testid="leptos-status-chip" data-status="offline" class="status-chip">Offline</div></section>
