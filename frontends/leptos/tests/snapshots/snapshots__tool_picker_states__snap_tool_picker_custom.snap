<div data-testid="leptos-tool-picker" class="new-session-config"><div data-testid="leptos-preset-row" class="preset-row"><button data-testid="leptos-preset-standard" data-preset-id="standard" class="preset-chip">Standard<span class="preset-tag">12 tools</span></button><button data-testid="leptos-preset-all" data-preset-id="all" class="preset-chip">+ Python REPL<span class="preset-tag">13 tools</span></button><button data-testid="leptos-preset-repl-centric" data-preset-id="repl-centric" class="preset-chip">REPL-centric<span class="preset-tag">3 tools</span></button><!><button data-testid="leptos-preset-custom" disabled tabindex="-1" class="preset-chip preset-chip-custom selected">Custom</button></div><div class="tool-grid-wrap"><div class="tool-group"><h4 class="tool-group-header">File ops</h4><div class="tool-grid"><label data-testid="leptos-tool-read_file" class="tool-check"><input type="checkbox"><code>read_file</code></label><label data-testid="leptos-tool-write_file" class="tool-check"><input type="checkbox"><code>write_file</code></label><label data-testid="leptos-tool-edit_file" class="tool-check"><input type="checkbox"><code>edit_file</code></label><label data-testid="leptos-tool-find_files" class="tool-check"><input type="checkbox"><code>find_files</code></label><label data-testid="leptos-tool-grep_files" class="tool-check"><input type="checkbox"><code>grep_files</code></label><label data-testid="leptos-tool-list_files" class="tool-check"><input type="checkbox"><code>list_files</code></label><!></div></div><div class="tool-group"><h4 class="tool-group-header">Shell</h4><div class="tool-grid"><label data-testid="leptos-tool-run_command" class="tool-check"><input type="checkbox"><code>run_command</code></label><label data-testid="leptos-tool-run_background" class="tool-check"><input type="checkbox"><code>run_background</code></label><label data-testid="leptos-tool-wait_for_output" class="tool-check"><input type="checkbox"><code>wait_for_output</code></label><label data-testid="leptos-tool-write_stdin" class="tool-check"><input type="checkbox"><code>write_stdin</code></label><!></div></div><div class="tool-group"><h4 class="tool-group-header">Web</h4><div class="tool-grid"><label data-testid="leptos-tool-web_search" class="tool-check"><input type="checkbox"><code>web_search</code></label><label data-testid="leptos-tool-fetch_url" class="tool-check"><input type="checkbox"><code>fetch_url</code></label><!></div></div><div class="tool-group"><h4 class="tool-group-header">REPL</h4><div class="tool-grid"><label data-testid="leptos-tool-python_repl" class="tool-check"><input type="checkbox"><code>python_repl</code></label><!></div></div><!></div><div class="config-actions"><span data-testid="leptos-tool-count" class="selected-count">11 of 13 tools selected</span><div class="config-actions-right"><button data-testid="leptos-tool-cancel" class="config-btn">Cancel</button><button data-testid="leptos-tool-create" class="config-btn config-btn-primary">Create session →</button></div></div></div>
